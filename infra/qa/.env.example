# QA environment secrets. Copy to `.env` next to docker-compose.qa.yml on the
# QA droplet (chmod 600) and fill in. NEVER commit the real .env.

# Postgres (QA-local container; data survives in the qa_pgdata volume)
DB_USERNAME=townbasket
DB_PASSWORD=change-me-qa-db-password

# JWT signing key — random, >=32 bytes. Different from production's.
JWT_SECRET=change-me-to-a-long-random-32-byte-minimum-secret

# Basic-auth gate for the three app hosts (NOT the api).
# Generate: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-qa-password'
QA_BASIC_AUTH_HASH=change-me-bcrypt-hash

# Storefront Google Maps browser key (optional in QA; pin-drop is disabled
# gracefully when empty). If set, add the qa domain to the key's referrer list.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
