# Production secrets template. Copy to `.env` on the droplet (chmod 600) and
# fill in real values. NEVER commit the real .env.

# Container registry
REGISTRY=registry.digitalocean.com/town-basket
TAG=latest

# Database (recommended: DO Managed Postgres)
DB_URL=jdbc:postgresql://db-host:25060/townbasket?sslmode=require
DB_USERNAME=townbasket
DB_PASSWORD=change-me

# Backups → DO Spaces (s3-compatible)
DB_URL_PG=postgres://townbasket:change-me@db-host:25060/townbasket?sslmode=require
SPACES_BUCKET=town-basket-backups
SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RETENTION_DAYS=30

# Auth (M4): app-issued JWT signing key — MUST be >= 32 bytes, random, secret.
JWT_SECRET=change-me-to-a-long-random-32-byte-minimum-secret

# Payment gateway (wired in M5; the Paytm->Razorpay vendor swap is still pending)
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=

# Firebase phone-OTP (M4). Backend verifier: set to your Firebase projectId to
# enable real OTP (disables the offline dev fake). A present-but-blank value makes
# the API refuse to start (fail-safe, not a silent downgrade) — keep it set to a
# real projectId in prod, or remove the env line entirely to run the offline fake.
FIREBASE_PROJECT_ID=town-basket

# Storefront BUILD args — Next.js inlines NEXT_PUBLIC_* at IMAGE BUILD time, so
# pass these when building the storefront image (not as runtime env). These are
# Firebase Web config values and are safe to expose in the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCeGmac68Mffr_hEKyMaodqHpI2afehRso
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=town-basket.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=town-basket
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=town-basket.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=661494495950
NEXT_PUBLIC_FIREBASE_APP_ID=1:661494495950:web:e554decc5ee8f8c92e2e9f

# Google Maps (storefront address pin-drop). Public BROWSER key, inlined at build
# time. The security control is the HTTP-referrer restriction — lock the key in
# Google Cloud to your domains (https://town-basket.com/*, https://*.town-basket.com/*,
# http://localhost:3000/* for dev) + restrict it to the "Maps JavaScript API".
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBT7nnGEdDd9y66tZCF2Ajv9QriIduxpuA
