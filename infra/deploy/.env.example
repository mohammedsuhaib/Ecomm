# Production secrets template. Copy to `.env` on the droplet (chmod 600) and
# fill in real values. NEVER commit the real .env.

# Container registry
REGISTRY=registry.digitalocean.com/town-basket
TAG=latest

# Database (recommended: DO Managed Postgres)
DB_URL=jdbc:postgresql://db-host:25060/townbasket?sslmode=require
DB_USERNAME=townbasket
DB_PASSWORD=change-me

# Backups → DO Spaces (s3-compatible)
DB_URL_PG=postgres://townbasket:change-me@db-host:25060/townbasket?sslmode=require
SPACES_BUCKET=town-basket-backups
SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
RETENTION_DAYS=30

# External vendors (wired in M4/M5)
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
FIREBASE_PROJECT_ID=
